<?xml version="1.0" encoding="UTF-8"?>
<schemalist gettext-domain="uptime-notifier">
  <schema id="org.gnome.shell.extensions.uptime-notifier" path="/org/gnome/shell/extensions/uptime-notifier/">
    <key name="format" type="s">
      <default>'human'</default>
      <summary>Display Format</summary>
      <description>Format of the uptime display. Values: 'human', 'compact'.</description>
      <choices>
        <choice value='human'/>
        <choice value='compact'/>
      </choices>
    </key>
    <key name="update-interval" type="i">
      <default>60</default>
      <summary>Update Interval</summary>
      <description>Time in seconds between updates.</description>
    </key>
    <key name="show-icon" type="b">
      <default>false</default>
      <summary>Show Icon</summary>
      <description>Whether to show an uptime icon in the panel.</description>
    </key>
  </schema>
</schemalist>
